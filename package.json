{
  "name": "iso11820-ts-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.main.json && vite build",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.main.json --noEmit",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "test": "npm run typecheck && npm run smoke"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "electron": "latest",
    "exceljs": "latest",
    "gsap": "latest",
    "pdfkit": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sql.js": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/pdfkit": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/sql.js": "latest",
    "typescript": "latest"
  }
}
